---
const base = import.meta.env.BASE_URL;
---
<section id="top" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid"></div>
    <div class="hero__blob hero__blob--1"></div>
    <div class="hero__blob hero__blob--2"></div>
  </div>

  <div class="container-x hero__inner">
    <div class="hero__copy">
      <div class="hero__live reveal">
        <span class="hero__live-dot"></span>
        <span>Принимаю клиентов · Москва и&nbsp;онлайн</span>
      </div>

      <h1 class="hero__title reveal">
        <span>Адвокат</span><br/>
        <span>Александр</span><br/>
        <em>Березовский.</em>
      </h1>

      <p class="hero__lead reveal">
        20&nbsp;лет защиты по&nbsp;уголовным делам, спорам с&nbsp;приставами,
        страховым и&nbsp;семейным делам. Москва, Адвокатская палата
        Волгоградской области, реестр №&nbsp;34/1410.
      </p>

      <div class="hero__actions reveal">
        <a href="#contact" class="btn btn--primary">
          Получить консультацию
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="tel:+79033150952" class="btn btn--ghost">
          +7 (903) 315-09-52
        </a>
      </div>

      <div class="hero__metrics reveal">
        <div class="hero__metric">
          <div class="hero__metric-num">20<small>+</small></div>
          <div class="hero__metric-label">лет практики</div>
        </div>
        <div class="hero__metric">
          <div class="hero__metric-num">1993</div>
          <div class="hero__metric-label">отзыва на&nbsp;9111.ru</div>
        </div>
        <div class="hero__metric">
          <div class="hero__metric-num">9</div>
          <div class="hero__metric-label">направлений практики</div>
        </div>
        <div class="hero__metric">
          <div class="hero__metric-num">0<small>₽</small></div>
          <div class="hero__metric-label">первая консультация</div>
        </div>
      </div>
    </div>

    <div class="hero__photo reveal-right">
      <div class="hero__photo-frame">
        <img src={`${base}img/berezovsky.jpg`} alt="Адвокат Александр Михайлович Березовский" />
      </div>
      <div class="hero__photo-badge">
        <div class="hero__photo-badge-num">20</div>
        <div class="hero__photo-badge-text">лет<br/>практики</div>
      </div>
      <div class="hero__photo-rating">
        <div class="hero__photo-rating-stars">★★★★★</div>
        <div class="hero__photo-rating-meta">
          <b>4.9</b> · 1993 отзыва
          <span>9111.ru</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 60px 0 90px;
  }
  .hero__bg { position: absolute; inset: 0; pointer-events: none; }
  .hero__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(11, 20, 36, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(11, 20, 36, 0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }
  .hero__blob {
    position: absolute; border-radius: 50%;
    filter: blur(40px);
  }
  .hero__blob--1 {
    top: -10%; right: -10%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(30, 58, 95, 0.10) 0%, transparent 65%);
  }
  .hero__blob--2 {
    bottom: -15%; left: -10%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(184, 146, 63, 0.08) 0%, transparent 65%);
  }

  .hero__inner {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 50px;
    align-items: center;
    padding-top: 40px;
  }

  /* === LEFT === */
  .hero__live {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 7px 14px;
    background: rgba(30, 58, 95, 0.06);
    border: 1px solid rgba(30, 58, 95, 0.15);
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--color-accent);
  }
  .hero__live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #2f8f5a;
    box-shadow: 0 0 0 4px rgba(47, 143, 90, 0.18);
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.75); opacity: 0.5; }
  }

  .hero__title {
    margin: 22px 0 0;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(46px, 7vw, 88px);
    font-weight: 500;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--color-text);
  }
  .hero__title em {
    font-style: italic; font-weight: 400;
    color: var(--color-gold-deep);
  }

  .hero__lead {
    margin: 28px 0 0;
    max-width: 520px;
    color: var(--color-text-soft);
    font-size: 17px;
    line-height: 1.7;
  }

  .hero__actions {
    margin-top: 36px;
    display: flex; flex-wrap: wrap; gap: 12px;
  }

  .hero__metrics {
    margin-top: 50px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 28px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .hero__metric { display: flex; flex-direction: column; }
  .hero__metric-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .hero__metric-num small {
    font-size: 0.5em;
    color: var(--color-gold-deep);
    font-weight: 400;
    margin-left: 3px;
  }
  .hero__metric-label {
    margin-top: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* === RIGHT — фото === */
  .hero__photo {
    position: relative;
    max-width: 460px;
    margin: 0 auto;
  }
  .hero__photo-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 8px;
    background: var(--color-bg-2);
    box-shadow:
      0 1px 2px rgba(11, 20, 36, 0.05),
      0 30px 60px rgba(11, 20, 36, 0.15);
  }
  .hero__photo-frame img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }

  .hero__photo-badge {
    position: absolute;
    top: 20px; left: -20px;
    background: var(--color-accent);
    color: #f7f4ee;
    padding: 14px 18px 12px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 12px 30px rgba(30, 58, 95, 0.3);
  }
  .hero__photo-badge-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 40px; font-weight: 500;
    line-height: 0.9;
    color: #d4a957;
  }
  .hero__photo-badge-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(247, 244, 238, 0.9);
    line-height: 1.3;
  }

  .hero__photo-rating {
    position: absolute;
    bottom: -16px; right: -10px;
    background: #f7f4ee;
    border: 1px solid var(--color-border);
    padding: 12px 16px;
    border-radius: 4px;
    box-shadow: 0 12px 30px rgba(11, 20, 36, 0.12);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero__photo-rating-stars {
    color: #b8923f;
    font-size: 14px;
    letter-spacing: 2px;
  }
  .hero__photo-rating-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.3px;
    color: var(--color-text-soft);
    display: flex;
    gap: 6px;
    align-items: baseline;
  }
  .hero__photo-rating-meta b {
    font-size: 13px;
    color: var(--color-text);
  }
  .hero__photo-rating-meta span {
    color: var(--color-muted-2);
    text-transform: uppercase;
  }

  @media (min-width: 880px) {
    .hero { padding: 70px 0 120px; }
    .hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 70px;
      padding-top: 60px;
    }
    .hero__metrics { grid-template-columns: repeat(4, 1fr); gap: 28px; }
  }
</style>
